{
  "name": "@longdech/bridge",
  "version": "1.0.3",
  "description": "Reusable HTTP, token, and React Query bridge utilities.",
  "license": "MIT",
  "packageManager": "pnpm@10.13.1",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "scripts": {
    "clean": "rimraf dist",
    "build": "pnpm clean && tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm typecheck && pnpm build",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [
    "bridge",
    "http-client",
    "token-manager",
    "react-query",
    "axios"
  ],
  "author": "longdech",
  "dependencies": {
    "axios": "^1.15.0",
    "jwt-decode": "^4.0.0"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.99.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
